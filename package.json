{
  "name": "@cryptocadet/cli",
  "version": "0.2.0",
  "description": "CryptoCadet v4 client package: agent hot-wallet signer + local policy engine (Base/USDC).",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "cryptocadet": "dist/cli/bin.js",
    "ccx": "dist/cli/bin.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./policy": "./dist/policy/evaluate.js"
  },
  "files": [
    "dist",
    "!dist/bin",
    "!dist/cli.cjs",
    "README.md"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "NODE_OPTIONS=--experimental-sqlite vitest run",
    "test:watch": "NODE_OPTIONS=--experimental-sqlite vitest",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ethers": "^6.13.0",
    "zod": "^3.25.76"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thetechjd/cryptocadet-cli.git"
  }
}
